@page
@model LoginModel

@{
    ViewData["Title"] = "Prijava";
}

<h1 class="text-center mb-4">@ViewData["Title"]</h1>
<div class="row justify-content-center">
    <div class="col-md-6 col-lg-4">
        <section class="card shadow-sm border-0">
            <div class="card-body">
                <form id="account" method="post" class="d-flex flex-column gap-3">
                    <div asp-validation-summary="ModelOnly" class="text-danger text-center" role="alert"></div>
                    <div class="form-floating">
                        <input asp-for="Input.Login" class="form-control" autocomplete="username" aria-required="true" placeholder="ime@example.com" />
                        <label asp-for="Input.Login" class="form-label">Uporabniško ime ali e-pošta</label>
                        <span asp-validation-for="Input.Login" class="text-danger"></span>
                    </div>
                    <div class="form-floating">
                        <input asp-for="Input.Password" class="form-control" autocomplete="current-password" aria-required="true" placeholder="geslo" />
                        <label asp-for="Input.Password" class="form-label">Geslo</label>
                        <span asp-validation-for="Input.Password" class="text-danger"></span>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" asp-for="Input.RememberMe" />
                        <label asp-for="Input.RememberMe" class="form-check-label">@Html.DisplayNameFor(m => m.Input.RememberMe)</label>
                    </div>
                    <button id="login-submit" type="submit" class="w-100 btn btn-lg btn-primary">Prijava</button>
                    <div class="text-center">
                        <p class="mb-1">
                            <a id="forgot-password" asp-page="./ForgotPassword">Ste pozabili geslo?</a>
                        </p>
                    </div>
                </form>
            </div>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
