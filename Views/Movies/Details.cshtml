@model Movie
@using System.Linq

@{
    ViewData["Title"] = "Podrobnosti filma";
}

<h1>Podrobnosti</h1>

<div class="mb-3">
    @{
        var bannerSource = string.IsNullOrWhiteSpace(Model.BannerUrl)
            ? Model.PosterUrl
            : Model.BannerUrl;
    }

    @if (!string.IsNullOrWhiteSpace(bannerSource))
    {
        <img src="@bannerSource"
             class="img-fluid rounded w-100"
             alt="@($"Pasica za film {Model.Title}")"
             onerror="this.onerror=null;this.src='@Url.Content("~/images/placeholder.jpg")';" />
    }
    else
    {
        <img src="@Url.Content("~/images/placeholder.jpg")"
             class="img-fluid rounded w-100"
             alt="Slika ni na voljo"
             onerror="this.onerror=null;this.src='@Url.Content("~/images/placeholder.jpg")';" />
    }
</div>

<div>
    <h4>Film</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Title)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Title)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Year)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Year)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Genre)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Genre)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.Description)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.Description)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.PosterUrl)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.PosterUrl)</dd>
        <dt class="col-sm-2">@Html.DisplayNameFor(model => model.BannerUrl)</dt>
        <dd class="col-sm-10">@Html.DisplayFor(model => model.BannerUrl)</dd>
    </dl>
</div>

<div>
    <h4>Komentarji</h4>
    <hr />
    @if (Model.Comments != null && Model.Comments.Any())
    {
        foreach (var comment in Model.Comments.OrderByDescending(c => c.CreatedAt))
        {
            <div class="mb-3 p-3 border rounded bg-light">
                <div class="d-flex justify-content-between">
                    <strong>@(comment.User?.UserName ?? "Neznan uporabnik")</strong>
                    <small class="text-muted">@comment.CreatedAt.ToString("dd. MM. yyyy")</small>
                </div>
                <p class="mb-0">@comment.Text</p>
            </div>
        }
    }
    else
    {
        <p class="text-muted">Za ta film še ni komentarjev.</p>
    }
</div>

<div>
    <a asp-action="Edit" asp-route-id="@Model?.Id">Uredi</a> |
    <a asp-action="Index">Nazaj na seznam</a>
</div>
