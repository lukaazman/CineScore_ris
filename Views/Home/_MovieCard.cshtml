@using System
@using System.Linq
@model MovieCardViewModel

@functions {
    public IEnumerable<string> GetGenres(string genreString)
    {
        if (string.IsNullOrWhiteSpace(genreString)) yield break;

        foreach (var genre in genreString
            .Split(',', StringSplitOptions.RemoveEmptyEntries)
            .Select(g => g.Trim())
            .Where(g => !string.IsNullOrWhiteSpace(g)))
        {
            yield return genre;
        }
    }
}

<div class="col-6 col-md-4 col-lg-3">
    <div class="card h-100 shadow-sm movie-card">
        @{
            var averageRating = Model.AverageRating ?? (double?)Model.Movie.Statistika?.PovprecjeOcen;
            var posterSource = string.IsNullOrWhiteSpace(Model.Movie.PosterUrl)
                ? Url.Content("~/images/placeholder.jpg")
                : Model.Movie.PosterUrl;
        }

        <a asp-controller="Movies"
           asp-action="Details_user"
           asp-route-id="@Model.Movie.Id"
           class="movie-poster-wrapper movie-poster-link">
            <img src="@posterSource"
                 class="img-fluid movie-poster"
                 alt="@Model.Movie.Title poster"
                 onerror="this.onerror=null;this.src='@Url.Content("~/images/placeholder.jpg")';" />

            <div class="movie-overlay">
                <div class="movie-overlay-content">
                    <div class="d-flex align-items-center justify-content-between gap-2 movie-year-row">
                        <div class="d-flex align-items-center justify-content-start gap-2 movie-year">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-calendar-event" viewBox="0 0 16 16">
                                <path d="M11 6.5a.5.5 0 0 1 .5-.5h1a.5.5 0 0 1 .5.5v1a.5.5 0 0 1-.5.5h-1a.5.5 0 0 1-.5-.5z" />
                                <path d="M3.5 0a.5.5 0 0 1 .5.5V1h8V.5a.5.5 0 0 1 1 0V1h1.5A1.5 1.5 0 0 1 16 2.5v11A1.5 1.5 0 0 1 14.5 15h-13A1.5 1.5 0 0 1 0 13.5v-11A1.5 1.5 0 0 1 1.5 1H3V.5a.5.5 0 0 1 .5-.5M1.5 2a.5.5 0 0 0-.5.5V4h14V2.5a.5.5 0 0 0-.5-.5zM15 5H1v8.5a.5.5 0 0 0 .5.5h13a.5.5 0 0 0 .5-.5z" />
                            </svg>
                            <span class="fw-semibold">@Model.Movie.Year</span>
                        </div>

                        @if (Model.ShowAverageRating)
                        {
                            <div class="d-flex align-items-center gap-2 movie-rating">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="bi bi-star-fill" viewBox="0 0 16 16">
                                    <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187z" />
                                </svg>
                                <span class="fw-semibold">@(averageRating.HasValue && averageRating > 0 ? $"{averageRating:0.0} / 5" : "N/A")</span>
                            </div>
                        }
                    </div>

                    <div class="d-flex flex-wrap gap-2 align-items-center movie-meta">
                        @foreach (var genre in GetGenres(Model.Movie.Genre))
                        {
                            <span class="badge genre-badge px-3 py-2 rounded-pill shadow-sm">@genre</span>
                        }
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>
