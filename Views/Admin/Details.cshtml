@model User

@{
    ViewData["Title"] = "Podrobnosti uporabnika";
    var roles = ViewBag.Roles as IEnumerable<string> ?? Array.Empty<string>();
}

<h1>Podrobnosti uporabnika</h1>

<dl class="row">
    <dt class="col-sm-2">Uporabniško ime</dt>
    <dd class="col-sm-10">@Model.UserName</dd>

    <dt class="col-sm-2">E-pošta</dt>
    <dd class="col-sm-10">@Model.Email</dd>

    <dt class="col-sm-2">Telefon</dt>
    <dd class="col-sm-10">@Model.PhoneNumber</dd>

    <dt class="col-sm-2">Vloge</dt>
    <dd class="col-sm-10">@string.Join(", ", roles)</dd>
</dl>

<div class="d-flex gap-2">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-primary">Uredi</a>
    <a asp-action="Users" class="btn btn-outline-secondary">Nazaj</a>
</div>
